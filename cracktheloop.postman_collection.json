        {
          "name": "Upload & Parse Resume",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "description": "Resume file (.pdf, .docx, .txt)",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "title",
                  "value": "Senior Software Architect Resume",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/resumes/upload",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "resumes",
                "upload"
              ]
            },
            "description": "Uploads a PDF, DOCX, or TXT resume and parses it into structured MongoDB fields using GPT-4o-mini."
          },
          "response": []
        },
