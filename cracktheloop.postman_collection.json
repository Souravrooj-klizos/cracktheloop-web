              "raw": "{\n  \"title\": \"Full Stack Developer\",\n  \"personal_details\": {\n    \"name\": \"John Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"phone\": \"+91 99999 88888\",\n    \"location\": \"Kolkata, India\"\n  },\n  \"summary\": \"Experienced Node.js and React engineer.\",\n  \"skills\": [\"JavaScript\", \"TypeScript\", \"React\", \"Node.js\", \"Express\", \"MongoDB\"],\n  \"education\": [\n    {\n      \"school\": \"Heritage Institute\",\n      \"degree\": \"B.Tech\",\n      \"field_of_study\": \"Information Technology\",\n      \"start_date\": \"2019\",\n      \"end_date\": \"2023\",\n      \"description\": \"First Class\"\n    }\n  ],\n  \"experience\": [\n    {\n      \"company\": \"Tech Solutions\",\n      \"position\": \"Backend Dev\",\n      \"location\": \"Kolkata\",\n      \"start_date\": \"2023-06\",\n      \"end_date\": \"Present\",\n      \"description\": \"Built RESTful APIs in Node.\"\n    }\n  ],\n  \"projects\": [\n    {\n      \"title\": \"Chat App\",\n      \"description\": \"Realtime Chat Application using Socket.io\",\n      \"technologies\": [\"React\", \"Express\", \"Socket.io\"]\n    }\n  ]\n}"
